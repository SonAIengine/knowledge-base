{
  "headers": [
    {
      "source": "**/*.{docx,xlsx,pptx,pdf,zip,hwp,jmx}",
      "headers": [
        { "key": "Content-Disposition", "value": "attachment" },
        { "key": "Connection", "value": "close" }
      ]
    },
    {
      "source": "**/*.{png,jpg,jpeg,gif,svg}",
      "headers": [
        { "key": "Connection", "value": "close" }
      ]
    }
  ]
}
